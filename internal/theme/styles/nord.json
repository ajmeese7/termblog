{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#eceff4",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "#4c566a"
  },
  "paragraph": {},
  "list": {
    "level_indent": 2,
    "color": "#eceff4"
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#88c0d0",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#2e3440",
    "background_color": "#88c0d0",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#81a1c1"
  },
  "h3": {
    "prefix": "### ",
    "color": "#88c0d0"
  },
  "h4": {
    "prefix": "#### ",
    "color": "#5e81ac"
  },
  "h5": {
    "prefix": "##### ",
    "color": "#a3be8c"
  },
  "h6": {
    "prefix": "###### ",
    "color": "#4c566a",
    "bold": false
  },
  "text": {
    "color": "#eceff4"
  },
  "strikethrough": {
    "crossed_out": true,
    "color": "#4c566a"
  },
  "emph": {
    "italic": true,
    "color": "#d8dee9"
  },
  "strong": {
    "bold": true,
    "color": "#88c0d0"
  },
  "hr": {
    "color": "#3b4252",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• ",
    "color": "#eceff4"
  },
  "enumeration": {
    "block_prefix": ". ",
    "color": "#eceff4"
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] ",
    "color": "#a3be8c"
  },
  "link": {
    "color": "#8fbcbb",
    "underline": true
  },
  "link_text": {
    "color": "#88c0d0",
    "bold": true
  },
  "image": {
    "color": "#b48ead",
    "underline": true
  },
  "image_text": {
    "color": "#4c566a",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#a3be8c",
    "background_color": "#3b4252"
  },
  "code_block": {
    "color": "#eceff4",
    "margin": 2,
    "chroma": {
      "text": { "color": "#eceff4" },
      "error": { "color": "#bf616a", "background_color": "#3b4252" },
      "comment": { "color": "#4c566a" },
      "comment_preproc": { "color": "#5e81ac" },
      "keyword": { "color": "#81a1c1" },
      "keyword_reserved": { "color": "#b48ead" },
      "keyword_namespace": { "color": "#81a1c1" },
      "keyword_type": { "color": "#8fbcbb" },
      "operator": { "color": "#81a1c1" },
      "punctuation": { "color": "#eceff4" },
      "name": { "color": "#eceff4" },
      "name_builtin": { "color": "#8fbcbb" },
      "name_tag": { "color": "#81a1c1" },
      "name_attribute": { "color": "#8fbcbb" },
      "name_class": { "color": "#8fbcbb", "underline": true, "bold": true },
      "name_constant": { "color": "#5e81ac" },
      "name_decorator": { "color": "#d08770" },
      "name_exception": { "color": "#bf616a" },
      "name_function": { "color": "#88c0d0" },
      "name_other": { "color": "#eceff4" },
      "literal": { "color": "#eceff4" },
      "literal_number": { "color": "#b48ead" },
      "literal_date": { "color": "#ebcb8b" },
      "literal_string": { "color": "#a3be8c" },
      "literal_string_escape": { "color": "#ebcb8b" },
      "generic_deleted": { "color": "#bf616a" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#a3be8c" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#4c566a" },
      "background": { "background_color": "#2e3440" }
    }
  },
  "table": {
    "color": "#eceff4"
  },
  "definition_list": {},
  "definition_term": {
    "color": "#88c0d0",
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n> ",
    "color": "#d8dee9"
  },
  "html_block": {},
  "html_span": {}
}
